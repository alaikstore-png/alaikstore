VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Public half of the VAPID key pair (see VAPID_PUBLIC_KEY below) — safe to expose in the frontend.
VITE_VAPID_PUBLIC_KEY=

# Payment gateways (set these as Supabase Edge Function secrets, never in frontend .env)
# Which gateway create-order should use: tripay | midtrans | xendit | duitku
PAYMENT_GATEWAY=tripay
# Public URL of your deployed frontend, used to build return/redirect URLs
APP_BASE_URL=https://your-domain.com
# Rupiah amount credited once to a referrer's balance on the referred user's first successful order
REFERRAL_BONUS=5000

TRIPAY_MODE=sandbox
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=

MIDTRANS_MODE=sandbox
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

XENDIT_SECRET_KEY=
# Verification token from Xendit Dashboard > Settings > Webhooks
XENDIT_CALLBACK_TOKEN=

# Duitku — https://docs.duitku.com/api/en/
DUITKU_MODE=sandbox
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=

# Resend — https://resend.com (set as Supabase Edge Function secrets)
# Powers automatic transactional emails: welcome email on sign-up, payment/topup
# success, and payment gagal/expired. Get RESEND_API_KEY from Resend dashboard.
RESEND_API_KEY=
# Must be a sender on a domain you've verified in Resend. Before verifying a
# domain you can leave this blank to fall back to Resend's shared test sender
# (onboarding@resend.dev), which only delivers to your own Resend account email.
RESEND_FROM_EMAIL=Alaikstore <no-reply@yourdomain.com>

# Web Push (VAPID) — powers push notifications (order status + flash sale
# announcements). Generate a key pair once with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY must ALSO be set in the frontend .env as VITE_VAPID_PUBLIC_KEY
# (same value, safe to expose — it's the public half of the key pair).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Top up providers (set as Supabase Edge Function secrets)
# Which provider provider-topup falls back to when a product has no catalog row yet
DEFAULT_PROVIDER=Digiflazz

# Digiflazz — https://developer.digiflazz.com
DIGIFLAZZ_USERNAME=
DIGIFLAZZ_API_KEY=
DIGIFLAZZ_WEBHOOK_SECRET=

# VIP Reseller / VIPayment — https://vip-reseller.co.id/page/api/game-feature
VIP_RESELLER_API_ID=
VIP_RESELLER_API_KEY=

# APIGames — https://docs.apigames.id
APIGAMES_MERCHANT_ID=
APIGAMES_SECRET=

# Tokovoucher — https://docs.tokovoucher.net
TOKOVOUCHER_MEMBER_CODE=
TOKOVOUCHER_SECRET=

# MedanPedia — https://medanpedia.co.id (SMM panel: followers/likes/views, not game top-up.
# Only relevant if you sell social-media boost products; map service IDs via `sku_code`)
MEDANPEDIA_API_ID=
MEDANPEDIA_API_KEY=

